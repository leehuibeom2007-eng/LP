import pygame
import sys

# 1. 기본 세팅: Pygame 초기화 및 화면 크기 설정 [파트 1 요구사항]
pygame.init()

SCREEN_WIDTH = 800
SCREEN_HEIGHT = 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
pygame.display.set_caption("학점 방어전")

# FPS 조절을 위한 시계 설정 [파트 1 요구사항]
clock = pygame.tick.Clock()
FPS = 60

# 색상 정의 (배경 및 임시 캐릭터용)
WHITE = (255, 255, 255)
BLUE = (0, 0, 255)

# 2. 주인공 캐릭터 설정 [파트 1 요구사항]
# 이미지 파일이 아직 없는 경우를 대비해 사각형(Rect)으로 기본 뼈대를 잡습니다.
# (추후 이미지가 준비되면 pygame.image.load()로 변경 가능)
character_width = 60
character_height = 80
character_x = (SCREEN_WIDTH / 2) - (character_width / 2)
# 화면 맨 아래에 배치 [파트 1 요구사항]
character_y = SCREEN_HEIGHT - character_height - 10 
character_speed = 7

# 게임 루프 구축 [파트 1 요구사항]
running = True
while running:
    # FPS 설정 (초당 프레임 조절) [파트 1 요구사항]
    clock.tick(FPS)
    
    # 이벤트 처리
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
            pygame.quit()
            sys.exit()

    # 3. 조작 시스템: 좌우 방향키 또는 A, D 키로 부드러운 이동 [파트 1 요구사항]
    keys = pygame.key.get_pressed()
    if keys[pygame.K_LEFT] or keys[pygame.K_a]:
        character_x -= character_speed
    if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
        character_x += character_speed

    # 4. 안전장치: 화면 밖(왼쪽, 오른쪽 끝)으로 뚫고 나가지 못하게 막는 경계선 처리 [파트 1 요구사항]
    if character_x < 0:
        character_x = 0
    elif character_x > SCREEN_WIDTH - character_width:
        character_x = SCREEN_WIDTH - character_width

    # 화면 그리기 (배경은 흰색)
    screen.fill(WHITE)
    
    # 주인공 캐릭터 화면에 렌더링 (임시로 파란색 사각형 배치)
    # 이미지 적용 시: screen.blit(character_image, (character_x, character_y))
    pygame.draw.rect(screen, BLUE, [character_x, character_y, character_width, character_height])

    # 화면 업데이트
    pygame.display.update()
